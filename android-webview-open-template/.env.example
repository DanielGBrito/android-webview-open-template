# Public app identity.
APP_NAME=Embedded Web App
APP_ID=com.opensource.webviewtemplate

# Website loaded inside the Android WebView.
WEBVIEW_URL=https://example.com

# Optional comma-separated hosts that can stay inside the WebView.
# The host from WEBVIEW_URL is always allowed automatically.
WEBVIEW_ALLOWED_HOSTS=

# Splash screen customization.
SPLASH_SUBTITLE=Powered by Android WebView
USER_AGENT_SUFFIX=EmbeddedWebViewApp/1.0

# Path relative to this project root for the app logo.
# Replace branding/logo.jpeg with your own JPEG, JPG, or PNG file.
APP_LOGO_PATH=branding/logo.jpeg

# Use true only if your site intentionally loads plain HTTP resources.
ALLOW_CLEARTEXT_TRAFFIC=false
