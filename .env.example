# ==========================================
# WEBVIEW EMBED CONFIGURATION (BOILERPLATE)
# ==========================================

# APPLICATION_ID: The unique package name for your app on Google Play Store (e.g. com.yourcompany.yourapp)
APPLICATION_ID=com.exemplo.app

# APP_NAME: The launcher name of your application.
APP_NAME=Nome do App

# APP_SUBTITLE: Slogan or short description shown on the splash screen.
APP_SUBTITLE=Subtítulo do App

# TARGET_URL: The URL of the website or PWA you want to embed.
TARGET_URL=https://seusite.com.br/

# TARGET_HOST: The host domain to check for internal vs external navigation.
# Links not matching this domain will open in the user's default browser.
TARGET_HOST=seusite.com.br

# USER_AGENT_SUFFIX: Custom string appended to the WebView's user agent.
USER_AGENT_SUFFIX=exemplo_Android1.0

# APP_LOGO_PATH: Path to the app logo image (relative to project root or absolute).
# Supported formats: png, jpg, jpeg, webp.
# This file will automatically be synced and copied to drawables on compilation.
APP_LOGO_PATH=app/src/main/res/drawable/custom_app_logo.png
